# ══════════════════════════════════════════════════════════════════
#  Paróquia Santa Terezinha — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores.
#  NUNCA faça commit do .env real.
# ══════════════════════════════════════════════════════════════════

# ── Banco de dados (OBRIGATÓRIO) ───────────────────────────────────
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/paroquia_db"

# ── JWT (OBRIGATÓRIO) ──────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque-por-uma-chave-de-64-bytes-minimo-gerada-aleatoriamente"
JWT_EXPIRES_IN="7d"

# ── Admin inicial (OBRIGATÓRIO para criar o primeiro admin) ────────
# Usado apenas pelo comando: npx prisma db seed
# Após criar o admin, estas variáveis podem ser removidas do ambiente
# de produção (o usuário já estará no banco).
ADMIN_EMAIL="seu-email@dominio.com"
ADMIN_PASSWORD="senha-forte-minimo-12-caracteres"
ADMIN_NAME="Administrador"

# ── Servidor e segurança (OPCIONAL) ───────────────────────────────
PORT=3000

# "production" ativa Helmet CSP completo e desativa o Swagger
NODE_ENV=development

# Origens permitidas no CORS — separe por vírgula para múltiplas
# Dev:  FRONTEND_URL=http://localhost:4200
# Prod: FRONTEND_URL=https://paroquia.com,https://www.paroquia.com
FRONTEND_URL=http://localhost:4200

# Rate limiting global (padrão: 100 req / 60s por IP)
# O endpoint /auth/login tem limite próprio: 5 req / 60s (fixo no código)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
