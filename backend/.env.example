# Banco de dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/paroquia_db"

# JWT — troque por uma string longa e aleatória em produção
JWT_SECRET="troque-por-uma-chave-secreta-forte"
JWT_EXPIRES_IN="7d"

# Porta da API (padrão: 3000)
PORT=3000
