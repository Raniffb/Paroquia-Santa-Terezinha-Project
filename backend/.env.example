# Banco de dados PostgreSQL (Docker — docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/paroquia_db"

# JWT — troque por uma string longa e aleatória em produção
JWT_SECRET="troque-por-uma-chave-secreta-forte"
JWT_EXPIRES_IN="7d"

# Porta da API (padrão: 3000)
PORT=3000
